rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isResearcher() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "chercheur";
    }

    function canReadSurvey(survey) {
      return isAdmin() ||
        (isResearcher() &&
          (survey.data.createdBy == request.auth.uid ||
           survey.data.assignedTo.hasAny([request.auth.uid])));
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    match /surveys/{surveyId} {
      allow read: if canReadSurvey(resource);
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isResearcher() && canReadSurvey(resource)
            && request.resource.data.createdBy == resource.data.createdBy);
      allow delete: if isAdmin();

      match /responses/{responseId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow create: if isResearcher()
          && canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)))
          && request.resource.data.userId == request.auth.uid;
        allow update: if isResearcher()
          && resource.data.userId == request.auth.uid;
        allow delete: if isAdmin();
      }

      match /lab_data/{docId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow write: if isResearcher()
          && canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
      }

      match /lek_responses/{docId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow write: if isResearcher()
          && canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
      }

      match /comments/{commentId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow create: if isSignedIn();
        allow delete: if isAdmin();
      }

      match /status_history/{entryId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow create: if isAdmin();
      }
    }

    match /lab_forms/{formId} {
      allow read: if isSignedIn() && (isAdmin()
        || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && (
        isAdmin() || request.resource.data.ownerId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId)
      );
      allow delete: if isAdmin();
    }

    match /terrain_forms/{formId} {
      allow read: if isSignedIn() && (isAdmin()
        || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && (
        isAdmin() || request.resource.data.ownerId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId)
      );
      allow delete: if isAdmin();
    }

    match /lek_forms/{formId} {
      allow read: if isSignedIn() && (isAdmin()
        || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && (
        isAdmin() || request.resource.data.ownerId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId)
      );
      allow delete: if isAdmin();
    }
  }
}
