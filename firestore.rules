rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOwnerDoc(doc) {
      return isSignedIn() && doc.data.ownerId == request.auth.uid;
    }

    function ownerMatchesResource() {
      return resource != null
        && resource.data != null
        && resource.data.ownerId == request.auth.uid;
    }

    function ownerMatchesRequest() {
      return request.resource != null
        && request.resource.data != null
        && request.resource.data.ownerId == request.auth.uid;
    }

    function isResearcher() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "chercheur";
    }

    function isOwnerOrAssigned(form) {
      return form.data.ownerId == request.auth.uid
        || (form.data.assignedTo is list
            && form.data.assignedTo.hasAny([request.auth.uid]));
    }

    function canReadSurvey(survey) {
      return isAdmin() ||
        (isResearcher() &&
          (survey.data.createdBy == request.auth.uid ||
           survey.data.assignedTo.hasAny([request.auth.uid])));
    }

    match /users/{uid} {
      allow read: if isAdmin() || isSelf(uid);
      allow create: if isAdmin() || isSelf(uid);
      allow update: if isAdmin()
        || (isSelf(uid) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /surveys/{surveyId} {
      allow read: if canReadSurvey(resource);
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isResearcher() && canReadSurvey(resource)
            && request.resource.data.createdBy == resource.data.createdBy);
      allow delete: if isAdmin();

      match /responses/{responseId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow create: if isResearcher()
          && canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)))
          && request.resource.data.userId == request.auth.uid;
        allow update: if isResearcher()
          && resource.data.userId == request.auth.uid;
        allow delete: if isAdmin();
      }

      match /lab_data/{docId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow write: if isResearcher()
          && canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
      }

      match /lek_responses/{docId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow write: if isResearcher()
          && canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
      }

      match /comments/{commentId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow create: if isSignedIn();
        allow delete: if isAdmin();
      }

      match /status_history/{entryId} {
        allow read: if canReadSurvey(get(/databases/$(database)/documents/surveys/$(surveyId)));
        allow create: if isAdmin();
      }
    }

    match /lab_forms/{formId} {
      allow read: if isAdmin() || isOwnerDoc(resource);
      allow create: if isSignedIn() && (
        isAdmin() || request.resource.data.ownerId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwnerDoc(resource)
          && request.resource.data.ownerId == resource.data.ownerId)
      );
      allow delete: if isAdmin() || isOwnerDoc(resource);

      match /attachments/{attachmentId} {
        allow read, create, update, delete: if isAdmin()
          || isOwnerDoc(get(/databases/$(database)/documents/lab_forms/$(formId)));
      }
    }

    match /terrain_forms/{formId} {
      allow read: if isAdmin() || isOwnerDoc(resource);
      allow create: if isSignedIn() && (
        isAdmin() || request.resource.data.ownerId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwnerDoc(resource)
          && request.resource.data.ownerId == resource.data.ownerId)
      );
      allow delete: if isAdmin() || isOwnerDoc(resource);
      match /attachments/{attachmentId} {
        allow read, create, update, delete: if isAdmin()
          || isOwnerDoc(get(/databases/$(database)/documents/terrain_forms/$(formId)));
      }
    }

    match /attachments_files/{attachmentId} {
      allow read, create, update, delete: if isAdmin()
        || (isSignedIn() && ownerMatchesResource())
        || (isSignedIn() && ownerMatchesRequest());

      match /chunks/{chunkId} {
        allow read, create, update, delete: if isAdmin()
          || (isSignedIn() && ownerMatchesResource())
          || (isSignedIn() && ownerMatchesRequest());
      }
    }

    match /lek_forms/{formId} {
      allow read: if isSignedIn() && (isAdmin()
        || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && (
        isAdmin() || request.resource.data.ownerId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId)
      );
      allow delete: if isAdmin();
    }
  }
}
